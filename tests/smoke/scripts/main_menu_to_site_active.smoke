# NOTE:
# This file is used only by the text smoke-test host (`gs1_smoke_host`).
# The live visual adapter (`gs1_visual_smoke_host`) does not load or execute
# this script anymore.

# Gameplay boot opens the main menu on the first frame.
wait_app_state MAIN_MENU 60

# Start a campaign and wait for regional map.
click_ui_action START_NEW_CAMPAIGN
wait_app_state REGIONAL_MAP 60

# Select the first site and start the attempt.
click_ui_action SELECT_DEPLOYMENT_SITE 1
wait_selected_site 1 60
click_ui_action START_SITE_ATTEMPT
wait_app_state SITE_ACTIVE 60

# Validate the site bootstrap projection path.
assert_app_state SITE_ACTIVE
assert_saw_command BEGIN_SITE_SNAPSHOT
assert_saw_command SITE_TILE_UPSERT
assert_saw_command SITE_WORKER_UPDATE
assert_saw_command SITE_CAMP_UPDATE
assert_saw_command SITE_WEATHER_UPDATE
assert_saw_command HUD_STATE
assert_log_contains BEGIN_SITE_SNAPSHOT mode=SNAPSHOT
assert_log_contains Started site attempt.
